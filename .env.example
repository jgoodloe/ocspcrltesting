# OCSP Testing Web — environment configuration
# Copy to .env for docker compose, or install as /etc/ocsp-testing-web.env for systemd.
# Every variable is optional; the defaults shown are what you get if unset.

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------
# Public base path when served under a reverse-proxy subpath (see
# nginx/subpath.conf). Leave empty for root deployment.
#OCSPWEB_BASE_PATH=/ocsp

# Optional absolute public URL, used for documentation/links only.
#OCSPWEB_PUBLIC_BASE_URL=https://ocsp.example.com

# Where run workspaces, uploads and the SQLite database live.
#OCSPWEB_DATA_DIR=/data

# Which upstream addresses may set X-Forwarded-* (client IP, proto, host). The
# container defaults to 127.0.0.1; set this to your reverse proxy's address or
# subnet so client IPs used for login rate-limiting and audit attribution are
# trustworthy. NEVER set it to '*' when the app is reachable beyond the proxy —
# that lets any client spoof its source IP.
#OCSPWEB_FORWARDED_ALLOW_IPS=127.0.0.1

# SQLAlchemy async database URL. PostgreSQL is the recommended engine for
# multi-user deployments (docker-compose provisions one by default); SQLite is
# fine for single-user/dev/CI. Default: sqlite in OCSPWEB_DATA_DIR.
#OCSPWEB_DATABASE_URL=postgresql+asyncpg://ocspweb:ocspweb@db:5432/ocspweb

# ---------------------------------------------------------------------------
# Multi-user authentication & sessions (security-sensitive)
# ---------------------------------------------------------------------------
# When NO auth is configured the app runs "open": a single anonymous admin and
# a shared "Default" workspace, matching the old single-user behaviour. Setting
# any of the values below turns authentication on.
#
# For safety the app now REFUSES TO START in open mode unless you explicitly
# opt in — otherwise anyone who can reach the port gets full admin. Configure
# auth (session secret + bootstrap password, or OIDC) for any shared/networked
# deployment; only set this for an isolated single-user/dev box.
#OCSPWEB_ALLOW_OPEN_MODE=false
#
# Every run, profile and saved certificate belongs to a workspace; users are
# members of workspaces with a role (viewer < member < admin). See docs/AUTH.md.

# Secret that signs session cookies. REQUIRED in production so sessions survive
# restarts and agree across workers. Generate with: openssl rand -hex 32
#OCSPWEB_SESSION_SECRET=change-me-to-a-long-random-value
#OCSPWEB_SESSION_TTL_SECONDS=28800
# Set false only when terminating TLS elsewhere and serving the app over plain
# HTTP internally (the cookie's Secure flag).
#OCSPWEB_SESSION_COOKIE_SECURE=true

# Break-glass local admin, created/refreshed at startup when a password is set.
# Use it to bootstrap OIDC or recover access. Username defaults to "admin".
#OCSPWEB_BOOTSTRAP_ADMIN_USERNAME=admin
#OCSPWEB_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Allow local username/password login in addition to OIDC. Set false to force
# OIDC-only (the break-glass admin still works).
#OCSPWEB_LOCAL_LOGIN_ENABLED=true

# --- OIDC (authentik or any OpenID Connect provider) ---
# All three of issuer/client-id/client-secret must be set to show the SSO
# button. Users are matched on the stable `sub` claim (never email). First
# login provisions the user and a personal workspace.
#OCSPWEB_OIDC_ISSUER=https://authentik.example.com/application/o/ocsp/
#OCSPWEB_OIDC_CLIENT_ID=...
#OCSPWEB_OIDC_CLIENT_SECRET=...
#OCSPWEB_OIDC_SCOPES=openid email profile
# Claim carrying group names; shared workspaces with a matching oidc_group get
# the user added automatically on login.
#OCSPWEB_OIDC_GROUP_CLAIM=groups

# Comma-separated list of allowed CORS origins. Leave empty (default) when the
# frontend is served by this app through nginx — no CORS is needed then.
#OCSPWEB_CORS_ORIGINS=https://tools.example.com

# ---------------------------------------------------------------------------
# Outbound request policy (SSRF protection — security-sensitive)
# ---------------------------------------------------------------------------
# The tool sends requests to user-supplied OCSP/CRL URLs. By default targets
# resolving to loopback, link-local, RFC1918/ULA private space or cloud
# metadata addresses are refused and logged. Set true ONLY for internal lab
# responders on private networks. Metadata IPs stay blocked even when true.
# In multi-user mode this is a HARD CEILING: a workspace may only enable private
# targets when this is true.
#OCSPWEB_ALLOW_PRIVATE_TARGETS=false

# Follow HTTP redirects from responders (each hop is re-validated). Default off.
#OCSPWEB_ALLOW_REDIRECTS=false

# Hard ceiling applied to every outbound request regardless of run settings.
#OCSPWEB_MAX_REQUEST_TIMEOUT_SECONDS=60

# Maximum bytes accepted from any OCSP/CRL/HTTP response.
#OCSPWEB_MAX_RESPONSE_BYTES=10485760

# Extra hostnames/IPs to refuse, comma-separated.
#OCSPWEB_EXTRA_BLOCKED_HOSTS=internal-billing.example,10.9.9.9

# ---------------------------------------------------------------------------
# Uploads & retention
# ---------------------------------------------------------------------------
# Maximum certificate upload size in bytes.
#OCSPWEB_MAX_UPLOAD_BYTES=5242880

# Run workspaces (uploaded certificates) older than this many days are purged.
# 0 disables the sweep.
#OCSPWEB_RETENTION_DAYS=30
#OCSPWEB_RETENTION_SWEEP_MINUTES=60

# ---------------------------------------------------------------------------
# Execution
# ---------------------------------------------------------------------------
# How many test runs may execute at the same time. In multi-user mode this is
# the deployment-wide ceiling; each workspace's own limit is capped by it.
#OCSPWEB_MAX_CONCURRENT_RUNS=2

# Default / maximum whole-run timeout in seconds.
#OCSPWEB_DEFAULT_RUN_TIMEOUT_SECONDS=900
#OCSPWEB_MAX_RUN_TIMEOUT_SECONDS=7200

# ---------------------------------------------------------------------------
# Logging / serving
# ---------------------------------------------------------------------------
#OCSPWEB_LOG_LEVEL=INFO
#OCSPWEB_LOG_JSON=false

# Gunicorn worker processes (Docker image only).
#GUNICORN_WORKERS=1
